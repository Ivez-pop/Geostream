# GeoStream Environment Configuration Template
# Copy this file to .env and customize values for local development

# HTTP Server configurations
PORT=8080

# Attached Backing Resources
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092

# Downstream Delivery
WEBHOOK_TARGET_URL=http://localhost:9000/callback

# Spatial Engine Thresholds
MAX_GEO_PRECISION_METERS=10
GEOHASH_PRECISION_CHARS=6
IDEMPOTENCY_TTL_SECONDS=3600
